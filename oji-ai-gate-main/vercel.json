{
  "version": 2,
  "name": "oji-api-gateway",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,OPTIONS,PATCH,DELETE,POST,PUT" },
        { "key": "Access-Control-Allow-Headers", "value": "X-CSRF-Token, X-Requested-With, Accept, Accept-Version, Content-Length, Content-MD5, Content-Type, Date, X-Api-Version, Authorization, apikey, X-File-Name" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/v1/api/chat/completions",
      "destination": "https://sawlpdzbovhgavlysrje.supabase.co/functions/v1/api/chat/completions"
    },
    {
      "source": "/v1/api/models",
      "destination": "https://sawlpdzbovhgavlysrje.supabase.co/functions/v1/api/models"
    },
    {
      "source": "/v1/api/upload-file",
      "destination": "https://sawlpdzbovhgavlysrje.supabase.co/functions/v1/api/upload-file"
    },
    {
      "source": "/v1/api/create-website",
      "destination": "https://sawlpdzbovhgavlysrje.supabase.co/functions/v1/api/create-website"
    },
    {
      "source": "/v1/api/status-sistem",
      "destination": "https://sawlpdzbovhgavlysrje.supabase.co/functions/v1/api/status-sistem"
    },
    {
      "source": "/v1/api/status-api",
      "destination": "https://sawlpdzbovhgavlysrje.supabase.co/functions/v1/api/status-api"
    },
    {
      "source": "/v1/api/mlbb/regionml",
      "destination": "https://sawlpdzbovhgavlysrje.supabase.co/functions/v1/mlbb?type=regionml"
    },
    {
      "source": "/v1/api/mlbb/firstml",
      "destination": "https://sawlpdzbovhgavlysrje.supabase.co/functions/v1/mlbb?type=firstml"
    },
    {
      "source": "/v1/api/mlbb/profilml",
      "destination": "https://sawlpdzbovhgavlysrje.supabase.co/functions/v1/mlbb?type=profilml"
    },
    {
      "source": "/v1/api/mlbb/stastikml",
      "destination": "https://sawlpdzbovhgavlysrje.supabase.co/functions/v1/mlbb?type=stastikml"
    },
    {
      "source": "/v1/api/mlbb/collectorml",
      "destination": "https://sawlpdzbovhgavlysrje.supabase.co/functions/v1/mlbb?type=collectorml"
    },
    {
      "source": "/v1/api",
      "destination": "https://sawlpdzbovhgavlysrje.supabase.co/functions/v1/api"
    },
    {
      "source": "/((?!v1/).*)",
      "destination": "/index.html"
    }
  ]
}
